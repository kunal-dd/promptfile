{
  "name": "promptfile",
  "version": "0.3.0",
  "description": "A single-file format and runtime for LLM prompts.",
  "type": "module",
  "license": "MIT",
  "author": "kunal-dd",
  "homepage": "https://github.com/kunal-dd/promptfile#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kunal-dd/promptfile.git"
  },
  "bugs": {
    "url": "https://github.com/kunal-dd/promptfile/issues"
  },
  "keywords": [
    "prompt",
    "llm",
    "ai",
    "anthropic",
    "claude",
    "openai",
    "gpt",
    "prompt-engineering",
    "prompt-management",
    "cli"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": { "promptfile": "./dist/cli.js" },
  "files": ["dist"],
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
